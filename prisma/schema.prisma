generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  tasks        Task[]
  habits       Habit[]
  goals        Goal[]
  moodEntries  MoodEntry[]
  energyEntries EnergyEntry[]
}

model Task {
  id        String      @id @default(cuid())
  userId    String
  title     String
  energy    String      @default("medium")
  done      Boolean     @default(false)
  dueAt     DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Habit {
  id          String            @id @default(cuid())
  userId      String
  name        String
  frequency   String
  energy      String            @default("medium")
  category    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  completions HabitCompletion[]

  @@index([userId, createdAt])
}

model HabitCompletion {
  id        String   @id @default(cuid())
  habitId   String
  dayKey    String
  done      Boolean  @default(true)
  createdAt DateTime @default(now())
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, dayKey])
  @@index([dayKey])
}

model Goal {
  id         String          @id @default(cuid())
  userId     String
  title      String
  category   String?
  targetDate DateTime?
  energy     String          @default("medium")
  status     String          @default("active")
  progress   Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones GoalMilestone[]

  @@index([userId, status])
}

model GoalMilestone {
  id        String   @id @default(cuid())
  goalId    String
  title     String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

model MoodEntry {
  id        String   @id @default(cuid())
  userId    String
  value     Int
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model EnergyEntry {
  id        String      @id @default(cuid())
  userId    String
  dayKey    String
  level     String
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey])
}

